<!DOCTYPE html>
<html lang="fr">
<%- include('../head') %>
<link rel="stylesheet" href="/public/styles/roles.css?v=1">

<body class="min-h-screen bg-[#f7f4ef] text-[#1f2937]">
  <%- include('../header') %>

  <main class="roles-main">
    <section class="roles-container">
      <div class="mb-8">
        <a href="/roles" class="text-sm font-medium text-[#b08a4a] hover:text-[#1d2d50]">Retour aux roles</a>
        <h1 class="roles-title"><%= title %></h1>
      </div>

      <% if (error) { %>
        <div class="roles-error">
          <%= error %>
        </div>
      <% } %>

      <form action="/roles/<%= role.id_role %>?_method=PUT" method="POST" class="roles-form">
        <div>
          <label for="name">Nom du role</label>
          <input
            type="text"
            id="name"
            name="name"
            value="<%= role.name || '' %>"
            required
            maxlength="50"
          >
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <button type="submit" class="roles-button">
            Mettre a jour
          </button>
          <a href="/roles" class="roles-link">
            Annuler
          </a>
        </div>
      </form>
    </section>
  </main>

  <%- include('../footer') %>
</body>
</html>

<!DOCTYPE html>
<html lang="fr">
<%- include('../head') %>

<body class="min-h-screen bg-[#f7f4ef] text-[#1f2937]">
  <%- include('../header') %>

  <main class="px-6 pb-16 pt-36">
    <section class="mx-auto max-w-5xl">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-[#b08a4a]">Administration</p>
          <h1 class="mt-2 font-serif text-4xl font-bold text-[#1d2d50]"><%= title %></h1>
        </div>

        <a href="/roles/add" class="inline-flex w-fit items-center justify-center rounded-md bg-[#1d2d50] px-5 py-3 font-medium text-white transition hover:bg-[#b08a4a]">
          Ajouter un role
        </a>
      </div>

      <% if (error) { %>
        <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-red-700">
          <%= error %>
        </div>
      <% } %>

      <div class="overflow-hidden rounded-md border border-[#ddd6cc] bg-white shadow-sm">
        <table class="w-full border-collapse text-left">
          <thead class="bg-[#1d2d50] text-white">
            <tr>
              <th class="px-5 py-4 text-sm font-semibold uppercase tracking-wide">ID</th>
              <th class="px-5 py-4 text-sm font-semibold uppercase tracking-wide">Nom du role</th>
              <th class="px-5 py-4 text-right text-sm font-semibold uppercase tracking-wide">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if (!roles.length) { %>
              <tr>
                <td colspan="3" class="px-5 py-8 text-center text-gray-500">Aucun role trouve.</td>
              </tr>
            <% } %>

            <% roles.forEach((role) => { %>
              <tr class="border-t border-[#eee5da]">
                <td class="px-5 py-4 text-gray-600"><%= role.id_role %></td>
                <td class="px-5 py-4 font-medium text-[#1d2d50]"><%= role.name %></td>
                <td class="px-5 py-4">
                  <div class="flex flex-wrap justify-end gap-2">
                    <a href="/roles/<%= role.id_role %>/users" class="rounded-md border border-[#d4c7b8] px-3 py-2 text-sm font-medium text-[#1d2d50] transition hover:bg-[#f7f4ef]">
                      Utilisateurs
                    </a>

                    <a href="/roles/edit/<%= role.id_role %>" class="rounded-md border border-[#b08a4a] px-3 py-2 text-sm font-medium text-[#8a6d3f] transition hover:bg-[#f7f4ef]">
                      Modifier
                    </a>

                    <form action="/roles/<%= role.id_role %>?_method=DELETE" method="POST">
                      <button type="submit" class="rounded-md bg-red-700 px-3 py-2 text-sm font-medium text-white transition hover:bg-red-800">
                        Supprimer
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <%- include('../footer') %>
</body>
</html>

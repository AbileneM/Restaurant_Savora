<!DOCTYPE html>
<html lang="fr">
<%- include('../head') %>

<body class="min-h-screen bg-[#f7f4ef] text-[#1f2937]">
  <%- include('../header') %>

  <main class="px-6 pb-16 pt-36">
    <section class="mx-auto max-w-4xl">
      <div class="mb-8">
        <a href="/roles" class="text-sm font-medium text-[#b08a4a] hover:text-[#1d2d50]">Retour aux roles</a>
        <h1 class="mt-3 font-serif text-4xl font-bold text-[#1d2d50]"><%= title %></h1>
        <% if (role) { %>
          <p class="mt-2 text-gray-600">Role: <span class="font-medium text-[#1d2d50]"><%= role.name %></span></p>
        <% } %>
      </div>

      <% if (error) { %>
        <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-red-700">
          <%= error %>
        </div>
      <% } %>

      <div class="overflow-hidden rounded-md border border-[#ddd6cc] bg-white shadow-sm">
        <table class="w-full border-collapse text-left">
          <thead class="bg-[#1d2d50] text-white">
            <tr>
              <th class="px-5 py-4 text-sm font-semibold uppercase tracking-wide">ID</th>
              <th class="px-5 py-4 text-sm font-semibold uppercase tracking-wide">Nom</th>
              <th class="px-5 py-4 text-sm font-semibold uppercase tracking-wide">Email</th>
            </tr>
          </thead>

          <tbody>
            <% if (!users.length) { %>
              <tr>
                <td colspan="3" class="px-5 py-8 text-center text-gray-500">Aucun utilisateur lie a ce role.</td>
              </tr>
            <% } %>

            <% users.forEach((user) => { %>
              <tr class="border-t border-[#eee5da]">
                <td class="px-5 py-4 text-gray-600"><%= user.id_user %></td>
                <td class="px-5 py-4 font-medium text-[#1d2d50]"><%= user.nom %></td>
                <td class="px-5 py-4 text-gray-700"><%= user.email %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <%- include('../footer') %>
</body>
</html>

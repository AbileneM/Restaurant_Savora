<!DOCTYPE html>
<html lang="fr">
<%- include('../head') %>
<link rel="stylesheet" href="/public/styles/roles.css?v=1">

<body class="min-h-screen bg-[#f7f4ef] text-[#1f2937]">
  <%- include('../header') %>

  <main class="roles-main">
    <section class="roles-container">
      <div class="mb-8">
        <a href="/roles" class="text-sm font-medium text-[#b08a4a] hover:text-[#1d2d50]">Retour aux roles</a>
        <h1 class="roles-title"><%= title %></h1>
        <% if (role) { %>
          <p class="mt-2 text-gray-600">Role: <span class="font-medium text-[#1d2d50]"><%= role.name %></span></p>
        <% } %>
      </div>

      <% if (error) { %>
        <div class="roles-error">
          <%= error %>
        </div>
      <% } %>

      <div class="roles-card">
        <table class="roles-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nom</th>
              <th>Email</th>
            </tr>
          </thead>

          <tbody>
            <% if (!users.length) { %>
              <tr>
                <td colspan="3" class="roles-muted">Aucun utilisateur lie a ce role.</td>
              </tr>
            <% } %>

            <% users.forEach((user) => { %>
              <tr>
                <td><%= user.id_user %></td>
                <td><strong><%= user.nom %></strong></td>
                <td><%= user.email %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <%- include('../footer') %>
</body>
</html>

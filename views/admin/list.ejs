<!DOCTYPE html>
<html lang="fr">
<%- include('../head') %>
<link rel="stylesheet" href="/public/styles/admin.css?v=1">

<body>
  <%- include('../header') %>

  <main class="admin-main">
    <section class="admin-container">
      <div class="admin-toolbar">
        <div>
          <a href="/admin" class="admin-link">Retour admin</a>
          <h1 class="admin-title"><%= resource.title %></h1>
        </div>

        <a href="/admin/<%= resourceName %>/add" class="admin-button">Ajouter</a>
      </div>

      <% if (error) { %>
        <div class="admin-error"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="admin-success"><%= success %></div>
      <% } %>

      <div class="admin-panel">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <% resource.columns.forEach(column => { %>
                <th><%= column.label %></th>
              <% }) %>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!rows.length) { %>
              <tr>
                <td colspan="<%= resource.columns.length + 2 %>" class="admin-muted">Aucune donnee trouvee.</td>
              </tr>
            <% } %>

            <% rows.forEach(row => { %>
              <tr>
                <td><%= row[resource.pk] %></td>
                <% resource.columns.forEach(column => { %>
                  <td><%= displayValue(column, row, refs) %></td>
                <% }) %>
                <td>
                  <div class="admin-actions">
                    <a href="/admin/<%= resourceName %>/edit/<%= row[resource.pk] %>" class="admin-link">Modifier</a>
                    <form
                      action="/admin/<%= resourceName %>/<%= row[resource.pk] %>?_method=DELETE"
                      method="POST"
                      onsubmit="return confirm('Confirmer la suppression ?');"
                    >
                      <button type="submit" class="admin-danger">Supprimer</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <%- include('../footer') %>
</body>
</html>

<!DOCTYPE html>
<html lang="fr">
<%- include('../head') %>
<link rel="stylesheet" href="/public/styles/users.css?v=1">

<body>
  <%- include('../header') %>

  <main class="users-main">
    <section class="users-container">
      <div class="users-toolbar">
        <div>
          <p class="users-kicker">Administration</p>
          <h1 class="users-title"><%= title %></h1>
        </div>

        <a href="/users/add" class="users-button">Ajouter un utilisateur</a>
      </div>

      <% if (error) { %>
        <div class="users-error"><%= error %></div>
      <% } %>

      <div class="users-card">
        <table class="users-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nom</th>
              <th>Email</th>
              <th>Role</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if (!users.length) { %>
              <tr>
                <td colspan="5" class="users-muted">Aucun utilisateur trouve.</td>
              </tr>
            <% } %>

            <% users.forEach((user) => { %>
              <tr>
                <td><%= user.id_user %></td>
                <td><strong><%= user.nom %></strong></td>
                <td><%= user.email %></td>
                <td><%= user.role ? user.role.name : 'Aucun role' %></td>
                <td>
                  <div class="users-actions">
                    <a href="/users/edit/<%= user.id_user %>" class="users-link">Modifier</a>
                    <form action="/users/<%= user.id_user %>?_method=DELETE" method="POST">
                      <button type="submit" class="users-danger">Supprimer</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <%- include('../footer') %>
</body>
</html>

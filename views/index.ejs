<!DOCTYPE html>
<html lang="en">
<%- include('head') %>
<body>

    <%- include('header') %>

<main>
  <section id="home" class="relative h-screen flex items-center justify-center overflow-hidden">

  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/public/images/background_img.jfif"
      alt="Elegant restaurant interior"
      class="w-full h-full object-cover"
    >

    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center text-white px-6">
    <h1 class="text-5xl md:text-7xl font-serif mb-4">
      Savora
    </h1>

    <p class="text-xl md:text-2xl mb-8 text-gray-200">
      Fine Dining Experience
    </p>

    <a
      href="/menu"
      class="inline-block bg-amber-700 hover:bg-amber-800 text-white px-8 py-3 rounded-full transition-colors"
    >
      View Menu
    </a>
  </div>

</section>

<section class="bg-white py-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    
    <img
      src="/public/images/logo-circle.png"
      alt="Savora Highlights Badge"
      class="w-96 md:w-84 mx-auto mb-10"
    >

    <h2 class="text-4xl md:text-6xl font-serif mb-8">
  <span class="text-[#1f2d4d]">Savora</span>
  <span class="text-[#b8873a] italic font-light">Highlights</span>
</h2>

    <p class="text-[#3f4b63] text-lg md:text-xl leading-10 max-w-3xl mx-auto">
      New dishes, seasonal specials, and exclusive events — Savora
      Highlights brings you the best of modern dining and latest updates.
    </p>

  </div>
</section>

<section id="about" class="py-20 px-6 bg-[#f7f5f3]">
  <div class="max-w-6xl mx-auto">
    
    <div class="grid md:grid-cols-2 gap-12 items-center">
      
      <!-- Text -->
      <div>
        <h2 class="text-4xl md:text-5xl font-serif text-[#1f2d4d] mb-6">
          Our Story
        </h2>

        <p class="text-gray-700 mb-4 leading-8">
          Welcome to Savora, where culinary artistry meets elegant ambiance.
          Since our opening, we've been dedicated to providing an unforgettable
          dining experience that celebrates both tradition and innovation.
        </p>

        <p class="text-gray-700 mb-4 leading-8">
          Our talented chefs craft each dish with the finest locally-sourced
          ingredients, ensuring every plate is a masterpiece. From intimate
          dinners to special celebrations, we're here to make your moments memorable.
        </p>

        <p class="text-gray-700 leading-8">
          Join us and discover why Savora has become the destination for those
          seeking exceptional cuisine in a sophisticated setting.
        </p>
      </div>

      <!-- Images -->
      <div class="grid grid-cols-2 gap-4">
        <img
          src="/public/images/highlight-1.jfif"
          alt="Elegant chandeliers"
          class="w-full h-64 object-cover rounded-lg shadow-lg"
        >

        <img
          src="/public/images/highlight-2.jfif"
          alt="Restaurant table setting"
          class="w-full h-64 object-cover rounded-lg shadow-lg mt-8"
        >
      </div>
    </div>
  </div>
</section>
 
<section class="bg-white py-16 px-6 md:px-10 lg:px-14">
  <div class="max-w-[1800px] mx-auto">

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-10">
      <h2 class="text-[#0f3550] text-3xl md:text-4xl lg:text-6xl uppercase tracking-wide font-serif">
        New + Notable
      </h2>

      <a
        href="/menu"
        class="inline-flex items-center gap-3 text-[#0f3550] text-lg md:text-xl font-medium hover:text-[#b8873a] transition-colors"
      >
        View The Menu
        <span class="text-2xl">→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-10">
      
      <article class="text-center">
        <div class="overflow-hidden">
          <img
            src="/public/images/Menu_steaks.png"
            alt="Surf&Turf"
            class="w-full h-[320px] md:h-[420px] lg:h-[460px] object-cover"
          >
        </div>
        <h3 class="mt-6 text-[#0f3550] text-2xl md:text-2xl uppercase font-medium tracking-wide">
          Surf&Turf 
        </h3>
      </article>

      <article class="text-center">
        <div class="overflow-hidden">
          <img
            src="/public/images/cocktail-signature.png"
            alt="Cocktail Crush"
            class="w-full h-[320px] md:h-[420px] lg:h-[460px] object-cover"
          >
        </div>
        <h3 class="mt-6 text-[#0f3550] text-2xl md:text-2xl uppercase font-medium tracking-wide">
          Signature Cocktails
        </h3>
      </article>

      <article class="text-center">
        <div class="overflow-hidden">
          <img
            src="/public/images/gourmet-dessert.png"
            alt="Gourmet Dessert"
            class="w-full h-[320px] md:h-[420px] lg:h-[460px] object-cover"
          >
        </div>
        <h3 class="mt-6 text-[#0f3550] text-2xl md:text-2xl uppercase font-medium tracking-wide">
          Gourmet Dessert
        </h3>
      </article>

    </div>
  </div>
</section>
</main>

<%- include('footer') %>

  <section id="menu"></section>
  <section id="reviews"></section>
  <section id="contact"></section>

</body>
</html>